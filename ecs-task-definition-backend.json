{
  "family": "taskflow-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::697863031884:role/taskflow-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::697863031884:role/taskflow-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "taskflow-backend",
      "image": "697863031884.dkr.ecr.eu-west-1.amazonaws.com/taskflow-backend:IMAGE_TAG",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",  "value": "production" },
        { "name": "PORT",      "value": "5000" },
        { "name": "OTEL_SERVICE_NAME",             "value": "taskflow-backend" },
        { "name": "OTEL_EXPORTER_OTLP_ENDPOINT",   "value": "http://MONITORING_HOST:4318" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taskflow-backend",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
